ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514
LLM_TEMPERATURE=0.4
LLM_MAX_OUTPUT_TOKENS=300
DEFAULT_REPLY_LANGUAGE=match-customer
SUPPORT_TONE=friendly, natural, human
SUPPORT_STYLE_NOTES=Reply like a real Pakistani e-commerce support person on WhatsApp. Keep it short, helpful, and natural.
VOICE_REPLY_STYLE_NOTES=For voice notes, sound casual and believable like a real WhatsApp seller. Use natural Pakistani conversational phrasing, keep it short, and avoid assistant-style wording.
OWNER_NUMBER=923106501781
PORT=3000
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_TRANSCRIPTION_LANGUAGE=ur
OPENAI_TRANSCRIPTION_PROMPT=Transcribe Urdu, Hindi, and Roman Urdu speech accurately.
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=
OPENAI_TTS_VOICE_GENDER=male
OPENAI_TTS_INSTRUCTIONS=Speak like a real person sending a quick WhatsApp voice note. Use slight natural pauses, relaxed pacing, and a believable conversational tone. Do not sound like an assistant, presenter, or announcer. Keep it calm, informal, and human.
VOICE_REPLY_ENABLED=true
FFMPEG_PATH=C:\path\to\ffmpeg.exe
